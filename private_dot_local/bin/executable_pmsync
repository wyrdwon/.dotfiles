#!/usr/bin/env bash
# =============================================================
# pmsync — derive packages.txt from system state
#
# Generates packages.txt in the chezmoi source directory by
# querying what is actually installed, then filtering against
# two control files (also in the chezmoi source root):
#
#   packages.exclude  — intentionally installed but should not
#                       replicate (experiments, orphans, etc.)
#   packages.local    — intentionally installed but machine-
#                       specific (hardware drivers, WSL tools,
#                       etc.); excluded from shared manifest
#
# Both files are plain lists, one package name per line.
# Lines starting with # are treated as comments.
#
# Usage:
#   pmsync [--dry-run]
#
#   --dry-run   Print what packages.txt would contain without
#               writing anything. Useful for auditing drift.
#
# After running, commit the result:
#   chezmoi re-add   (if packages.txt is tracked via chezmoi)
#   chezmoi git -- add -A && chezmoi git -- commit
# =============================================================

set -euo pipefail

# -------------------------------------------------------------
# Paths
# -------------------------------------------------------------
SOURCE_DIR="$(chezmoi source-path)"
PACKAGES_FILE="$SOURCE_DIR/packages.txt"
EXCLUDE_FILE="$SOURCE_DIR/packages.exclude"
LOCAL_FILE="$SOURCE_DIR/packages.local"

DRY_RUN=0
[[ "${1:-}" == "--dry-run" ]] && DRY_RUN=1

# -------------------------------------------------------------
# Helpers
# -------------------------------------------------------------
info()    { printf '\e[34m[pmsync]\e[0m  %s\n' "$*"; }
success() { printf '\e[32m[pmsync]\e[0m  %s\n' "$*"; }
warn()    { printf '\e[33m[pmsync]\e[0m  %s\n' "$*"; }

# Parse a plain list file, stripping comments and blank lines
parse_list() {
  local file="$1"
  [[ -f "$file" ]] && grep -v '^\s*#' "$file" | grep -v '^\s*$' | sort || true
}

# Set-subtract: lines in $1 not present in $2 or $3
subtract() {
  comm -23 <(sort "$1") <(sort -u <(cat "${@:2}"))
}

# -------------------------------------------------------------
# Ensure control files exist
# -------------------------------------------------------------
[[ -f "$EXCLUDE_FILE" ]] || {
  warn "packages.exclude not found — creating empty file at $EXCLUDE_FILE"
  touch "$EXCLUDE_FILE"
}
[[ -f "$LOCAL_FILE" ]] || {
  warn "packages.local not found — creating empty file at $LOCAL_FILE"
  touch "$LOCAL_FILE"
}

# -------------------------------------------------------------
# Build filter: union of exclude + local
# Anything in either file is suppressed from the manifest
# -------------------------------------------------------------
filter=$(mktemp)
trap 'rm -f "$filter"' EXIT
{
  parse_list "$EXCLUDE_FILE"
  parse_list "$LOCAL_FILE"
} | sort -u > "$filter"

# -------------------------------------------------------------
# Query installed state per source
# -------------------------------------------------------------

# Pacman: explicitly installed, not in base or base-devel
# -Qeq gives names only, explicit installs only
pacman_installed=$(mktemp)
pacman -Qeq | sort > "$pacman_installed"

# Cargo
cargo_installed=$(mktemp)
cargo install --list 2>/dev/null \
  | grep '^[a-zA-Z]' \
  | awk '{print $1}' \
  | sort > "$cargo_installed"

# pipx
pipx_installed=$(mktemp)
pipx list --short 2>/dev/null \
  | awk '{print $1}' \
  | sort > "$pipx_installed"

# Apply filter to each
pacman_final=$(comm -23 "$pacman_installed" "$filter")
cargo_final=$(comm -23 "$cargo_installed" "$filter")
pipx_final=$(comm -23 "$pipx_installed" "$filter")

# -------------------------------------------------------------
# Compose output
# -------------------------------------------------------------
output=$(mktemp)
cat > "$output" << 'HEADER'
# =============================================================
# packages.txt — generated by pmsync, do not edit by hand
#
# To exclude a package from replication:
#   add it to packages.exclude  (experiments, orphans)
#   add it to packages.local    (machine-specific installs)
#
# Regenerate:
#   pmsync
# =============================================================

HEADER

{
  echo "[pacman]"
  echo "$pacman_final"
  echo ""
  echo "[aur]"
  # AUR packages: explicitly installed packages not in the official repos
  # Derived by checking which explicitly installed packages are foreign (AUR)
  pacman -Qmq | sort | comm -23 - "$filter" || true
  echo ""
  echo "[cargo]"
  echo "$cargo_final"
  echo ""
  echo "[pipx]"
  echo "$pipx_final"
} >> "$output"

# -------------------------------------------------------------
# Dry run or write
# -------------------------------------------------------------
if [[ $DRY_RUN -eq 1 ]]; then
  info "Dry run — packages.txt would contain:"
  echo "---"
  cat "$output"
  echo "---"
else
  cp "$output" "$PACKAGES_FILE"
  success "packages.txt written to $PACKAGES_FILE"
  info "Review, then commit:"
  printf '    chezmoi git -- add -A\n'
  printf '    chezmoi git -- commit -m "sync packages"\n'
fi

# -------------------------------------------------------------
# Report: what changed vs previous packages.txt
# (shown in both dry-run and write modes)
# -------------------------------------------------------------
if [[ -f "$PACKAGES_FILE" ]] && git -C "$SOURCE_DIR" diff --quiet -- packages.txt 2>/dev/null; then
  success "No changes to packages.txt."
elif [[ -f "$PACKAGES_FILE" ]]; then
  info "Diff vs previous:"
  git -C "$SOURCE_DIR" diff -- packages.txt 2>/dev/null || diff /dev/null "$output" || true
fi

# Cleanup
rm -f "$pacman_installed" "$cargo_installed" "$pipx_installed" "$output"
